{
  "enabled": true,
  "name": "Lint on Save",
  "description": "Runs Pint format check when PHP files in app/ or tests/ are saved",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "app/**/*.php",
      "tests/**/*.php"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "composer lint:test",
    "timeout": 30
  }
}